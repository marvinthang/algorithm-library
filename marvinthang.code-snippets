            "                    low[u] = min(low[u], low[v]);",
            "                } else low[u] = min(low[u], num[v]);",
            "            }",
            "            if (low[u] == num[u]) {",
            "                int v;",
            "                do {",
            "                    v = visited.back(); visited.pop_back();",
            "                    num[v] = n;",
            "                    ids[v] = group_num;",
            "                } while (v != u);",
            "                group_num++;",
            "            }",
            "        };",
            "        for (int i = 0; i < n; i++) if (num[i] == -1) dfs(dfs, i);",
