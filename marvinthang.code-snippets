    "NUMBER_THEORETIC_TRANSFORM": {
        "scope": "cpp",
        "prefix": "NUMBER_THEORETIC_TRANSFORM",
        "body": [
            "namespace NUMBER_THEORETIC_TRANSFORM {",
            "template <typename Modular> class NTT {",
            "public:",
            "    static int md, base, max_base;",
