            "            TM cur = lines[i].eval(x);",
            "            if (!res.is_valid || val > cur) res = lines[i], val = cur;",
            "        }",
            "        return Result(res.a, res.b, res.id, res.is_valid, val);",
            "    }",
            "};"
        ],
